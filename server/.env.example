# ── Server ────────────────────────────────────────────────
PORT=5000
# Where the React client runs (used for CORS + Stripe redirect URLs)
CLIENT_URL=http://localhost:5173

# ── Database (Neon PostgreSQL) ────────────────────────────
# Create a free project at https://neon.tech and copy the connection string.
# Use the POOLED connection string (host contains "-pooler"). Keep ?sslmode=require.
# Example: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ── Auth ──────────────────────────────────────────────────
# Change this to a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret

# ── Match streams — BOHO / SportSRC (primary) ─────────────
# https://rapidapi.com/bohodevmail/api/football-streaming-api-match-data
BOHO_RAPIDAPI_KEY=
BOHO_RAPIDAPI_HOST=football-streaming-api-match-data.p.rapidapi.com

# ── Match streams — 1xapi (fallback if BOHO key is empty) ─
RAPIDAPI_KEY=
RAPIDAPI_HOST=football-live-streaming-api.p.rapidapi.com

# ── Payments (NOWPayments — USDT) ─────────────────────────
# Create an account at https://nowpayments.io, add a payout wallet, then:
#   Store Settings → API keys      -> NOWPAYMENTS_API_KEY
#   Store Settings → IPN/Callbacks -> set the IPN secret + callback URL
# Leave NOWPAYMENTS_API_KEY blank to run payments in MOCK mode (no real charge).
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
# Which coin to charge in. usdtbsc = USDT BEP-20 (BNB Smart Chain).
# Others: usdttrc20 (TRON), usdterc20 (Ethereum), usdtmatic (Polygon).
PAY_CURRENCY=usdtbsc
# Public URL of THIS backend, used for the IPN webhook callback.
# e.g. https://footballlive-production.up.railway.app
PUBLIC_SERVER_URL=
# Price in USD cents (500 = $5.00 ≈ 5 USDT, since USDT ≈ $1)
ACCESS_PRICE_CENTS=500
