# ── Server ────────────────────────────────────────────────
PORT=5000
# Where the React client runs (used for CORS + Stripe redirect URLs)
CLIENT_URL=http://localhost:5173

# ── Database (Neon PostgreSQL) ────────────────────────────
# Create a free project at https://neon.tech and copy the connection string.
# Use the POOLED connection string (host contains "-pooler"). Keep ?sslmode=require.
# Example: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ── Auth ──────────────────────────────────────────────────
# Change this to a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret

# ── Football API (RapidAPI) ───────────────────────────────
# Get a key at https://rapidapi.com/1xapi-rapid-team/api/football-live-streaming-api
# Leave blank to run on bundled mock data.
RAPIDAPI_KEY=
RAPIDAPI_HOST=football-live-streaming-api.p.rapidapi.com

# ── Stripe ────────────────────────────────────────────────
# Get test keys at https://dashboard.stripe.com/test/apikeys
# Leave STRIPE_SECRET_KEY blank to run payments in MOCK mode (no real charge).
STRIPE_SECRET_KEY=
# Price in USD cents charged for streaming access (500 = $5.00)
ACCESS_PRICE_CENTS=500
