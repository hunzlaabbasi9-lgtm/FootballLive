# Frontend env (Vite). Copy to .env.local for local overrides.
#
# Leave UNSET for local development — the app uses "/api" and Vite proxies
# it to the local backend (http://localhost:5000).
#
# In production (Vercel), set this to your Railway backend URL + /api:
#   VITE_API_BASE=https://your-app.up.railway.app/api
VITE_API_BASE=
